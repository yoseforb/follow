{
  "annotations": { "list": [] },
  "editable": true,
  "graphTooltip": 1,
  "links": [],
  "panels": [
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 100,
      "title": "CPU",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "decimals": 1,
          "min": 0,
          "max": 1,
          "color": { "mode": "thresholds" },
          "thresholds": { "steps": [
            { "color": "green", "value": null },
            { "color": "yellow", "value": 0.7 },
            { "color": "red", "value": 0.9 }
          ]}
        }
      },
      "gridPos": { "h": 6, "w": 6, "x": 0, "y": 1 },
      "id": 1,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] } },
      "title": "CPU Usage",
      "type": "stat",
      "targets": [
        {
          "expr": "1 - avg(rate(node_cpu_seconds_total{mode=\"idle\",job=\"node-exporter\"}[5m]))",
          "legendFormat": "CPU"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "custom": { "fillOpacity": 20, "stacking": { "mode": "normal" } }
        },
        "overrides": [
          { "matcher": { "id": "byName", "options": "user" }, "properties": [{ "id": "color", "value": { "fixedColor": "blue", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "system" }, "properties": [{ "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "iowait" }, "properties": [{ "id": "color", "value": { "fixedColor": "yellow", "mode": "fixed" } }] }
        ]
      },
      "gridPos": { "h": 8, "w": 18, "x": 6, "y": 1 },
      "id": 2,
      "title": "CPU Usage Over Time",
      "type": "timeseries",
      "targets": [
        { "expr": "avg(rate(node_cpu_seconds_total{mode=\"user\",job=\"node-exporter\"}[5m]))", "legendFormat": "user" },
        { "expr": "avg(rate(node_cpu_seconds_total{mode=\"system\",job=\"node-exporter\"}[5m]))", "legendFormat": "system" },
        { "expr": "avg(rate(node_cpu_seconds_total{mode=\"iowait\",job=\"node-exporter\"}[5m]))", "legendFormat": "iowait" }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "decimals": 2,
          "color": { "mode": "thresholds" },
          "thresholds": { "steps": [
            { "color": "green", "value": null },
            { "color": "yellow", "value": 5 },
            { "color": "red", "value": 15 }
          ]}
        }
      },
      "gridPos": { "h": 6, "w": 6, "x": 0, "y": 7 },
      "id": 3,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] } },
      "title": "Load Average (1m)",
      "type": "stat",
      "targets": [
        { "expr": "node_load1{job=\"node-exporter\"}", "legendFormat": "load1" }
      ]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 14 },
      "id": 101,
      "title": "Memory",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "decimals": 1,
          "min": 0,
          "max": 1,
          "color": { "mode": "thresholds" },
          "thresholds": { "steps": [
            { "color": "green", "value": null },
            { "color": "yellow", "value": 0.75 },
            { "color": "red", "value": 0.9 }
          ]}
        }
      },
      "gridPos": { "h": 6, "w": 6, "x": 0, "y": 15 },
      "id": 4,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] } },
      "title": "Memory Usage",
      "type": "stat",
      "targets": [
        {
          "expr": "1 - (node_memory_MemAvailable_bytes{job=\"node-exporter\"} / node_memory_MemTotal_bytes{job=\"node-exporter\"})",
          "legendFormat": "used"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "custom": { "fillOpacity": 20, "stacking": { "mode": "normal" } }
        }
      },
      "gridPos": { "h": 8, "w": 18, "x": 6, "y": 15 },
      "id": 5,
      "title": "Memory Breakdown",
      "type": "timeseries",
      "targets": [
        { "expr": "node_memory_MemTotal_bytes{job=\"node-exporter\"} - node_memory_MemAvailable_bytes{job=\"node-exporter\"}", "legendFormat": "used" },
        { "expr": "node_memory_Cached_bytes{job=\"node-exporter\"}", "legendFormat": "cached" },
        { "expr": "node_memory_Buffers_bytes{job=\"node-exporter\"}", "legendFormat": "buffers" },
        { "expr": "node_memory_MemAvailable_bytes{job=\"node-exporter\"}", "legendFormat": "available" }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "color": { "mode": "thresholds" },
          "thresholds": { "steps": [{ "color": "blue", "value": null }] }
        }
      },
      "gridPos": { "h": 6, "w": 6, "x": 0, "y": 21 },
      "id": 6,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] } },
      "title": "Total Memory",
      "type": "stat",
      "targets": [
        { "expr": "node_memory_MemTotal_bytes{job=\"node-exporter\"}", "legendFormat": "total" }
      ]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 28 },
      "id": 102,
      "title": "Disk",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "decimals": 1,
          "min": 0,
          "max": 1,
          "color": { "mode": "thresholds" },
          "thresholds": { "steps": [
            { "color": "green", "value": null },
            { "color": "yellow", "value": 0.75 },
            { "color": "red", "value": 0.9 }
          ]}
        }
      },
      "gridPos": { "h": 6, "w": 6, "x": 0, "y": 29 },
      "id": 7,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] } },
      "title": "Disk Usage (/)",
      "type": "stat",
      "targets": [
        {
          "expr": "1 - (node_filesystem_avail_bytes{mountpoint=\"/\",job=\"node-exporter\"} / node_filesystem_size_bytes{mountpoint=\"/\",job=\"node-exporter\"})",
          "legendFormat": "used"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "color": { "mode": "thresholds" },
          "thresholds": { "steps": [
            { "color": "green", "value": null },
            { "color": "yellow", "value": 2147483648 },
            { "color": "red", "value": 1073741824 }
          ]}
        }
      },
      "gridPos": { "h": 6, "w": 6, "x": 6, "y": 29 },
      "id": 8,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] } },
      "title": "Disk Free (/)",
      "type": "stat",
      "targets": [
        { "expr": "node_filesystem_avail_bytes{mountpoint=\"/\",job=\"node-exporter\"}", "legendFormat": "free" }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "unit": "Bps",
          "custom": { "fillOpacity": 10 }
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 29 },
      "id": 9,
      "title": "Disk I/O",
      "type": "timeseries",
      "targets": [
        { "expr": "rate(node_disk_read_bytes_total{job=\"node-exporter\"}[5m])", "legendFormat": "read {{device}}" },
        { "expr": "rate(node_disk_written_bytes_total{job=\"node-exporter\"}[5m])", "legendFormat": "write {{device}}" }
      ]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 38 },
      "id": 103,
      "title": "Network",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "unit": "Bps",
          "custom": { "fillOpacity": 10 }
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 39 },
      "id": 10,
      "title": "Network Traffic",
      "type": "timeseries",
      "targets": [
        { "expr": "rate(node_network_receive_bytes_total{device!~\"lo|docker.*|br-.*|veth.*\",job=\"node-exporter\"}[5m])", "legendFormat": "rx {{device}}" },
        { "expr": "rate(node_network_transmit_bytes_total{device!~\"lo|docker.*|br-.*|veth.*\",job=\"node-exporter\"}[5m])", "legendFormat": "tx {{device}}" }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": { "fillOpacity": 10 }
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 39 },
      "id": 11,
      "title": "Network Errors",
      "type": "timeseries",
      "targets": [
        { "expr": "rate(node_network_receive_errs_total{device!~\"lo|docker.*|br-.*|veth.*\",job=\"node-exporter\"}[5m])", "legendFormat": "rx errors {{device}}" },
        { "expr": "rate(node_network_transmit_errs_total{device!~\"lo|docker.*|br-.*|veth.*\",job=\"node-exporter\"}[5m])", "legendFormat": "tx errors {{device}}" }
      ]
    }
  ],
  "templating": {
    "list": [
      {
        "current": { "text": "Prometheus", "value": "Prometheus" },
        "hide": 2,
        "name": "DS_PROMETHEUS",
        "type": "datasource",
        "query": "prometheus"
      }
    ]
  },
  "time": { "from": "now-3h", "to": "now" },
  "refresh": "30s",
  "schemaVersion": 39,
  "tags": ["host", "observability"],
  "title": "Node Exporter — Host Metrics",
  "uid": "node-exporter-host"
}
