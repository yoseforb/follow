          "expr": "container_memory_working_set_bytes{name=~\"follow-.+\",job=\"cadvisor\"} / container_spec_memory_limit_bytes{name=~\"follow-.+\",job=\"cadvisor\"} > 0",
          "legendFormat": "{{name}}"
        }
