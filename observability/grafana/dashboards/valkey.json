{
  "annotations": { "list": [] },
  "editable": true,
  "graphTooltip": 1,
  "links": [],
  "panels": [
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 100,
      "title": "Overview",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "steps": [
            { "color": "red", "value": null },
            { "color": "green", "value": 1 }
          ]}
        }
      },
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 1 },
      "id": 1,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background", "textMode": "value" },
      "title": "Valkey Up",
      "type": "stat",
      "targets": [
        {
          "expr": "redis_up{job=\"valkey-exporter\"}",
          "legendFormat": "up"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": { "unit": "dtdurations" }
      },
      "gridPos": { "h": 4, "w": 4, "x": 4, "y": 1 },
      "id": 2,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "none", "textMode": "value" },
      "title": "Uptime",
      "type": "stat",
      "targets": [
        {
          "expr": "redis_uptime_in_seconds{job=\"valkey-exporter\"}",
          "legendFormat": "uptime"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": { "unit": "short" }
      },
      "gridPos": { "h": 4, "w": 4, "x": 8, "y": 1 },
      "id": 3,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "none", "textMode": "value" },
      "title": "Connected Clients",
      "type": "stat",
      "targets": [
        {
          "expr": "redis_connected_clients{job=\"valkey-exporter\"}",
          "legendFormat": "clients"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": { "unit": "ops", "decimals": 1 }
      },
      "gridPos": { "h": 4, "w": 4, "x": 12, "y": 1 },
      "id": 4,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "none", "textMode": "value" },
      "title": "Commands / sec",
      "type": "stat",
      "targets": [
        {
          "expr": "rate(redis_commands_processed_total{job=\"valkey-exporter\"}[5m])",
          "legendFormat": "ops"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": { "unit": "percentunit", "decimals": 1 }
      },
      "gridPos": { "h": 4, "w": 4, "x": 16, "y": 1 },
      "id": 5,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "none", "textMode": "value" },
      "title": "Hit Rate",
      "type": "stat",
      "targets": [
        {
          "expr": "rate(redis_keyspace_hits_total{job=\"valkey-exporter\"}[5m]) / (rate(redis_keyspace_hits_total{job=\"valkey-exporter\"}[5m]) + rate(redis_keyspace_misses_total{job=\"valkey-exporter\"}[5m]))",
          "legendFormat": "hit rate"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": { "unit": "short", "decimals": 2 }
