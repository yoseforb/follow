      "targets": [
        {
          "expr": "redis_memory_used_bytes{job=\"valkey-exporter\"}",
          "legendFormat": "Used"
        },
        {
          "expr": "redis_memory_max_bytes{job=\"valkey-exporter\"} > 0",
          "legendFormat": "Max"
        }
      ]
