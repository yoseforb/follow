      "type": "timeseries",
      "targets": [
        {
          "expr": "redis_mem_fragmentation_ratio{job=\"valkey-exporter\"}",
          "legendFormat": "Fragmentation"
        }
      ]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 14 },
