      "type": "stat",
      "targets": [
        {
          "expr": "redis_mem_fragmentation_ratio{job=\"valkey-exporter\"}",
          "legendFormat": "ratio"
        }
      ]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 5 },
      "id": 101,
      "title": "Memory",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "custom": { "fillOpacity": 15 }
        }
