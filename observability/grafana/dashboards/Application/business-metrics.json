        }
      },
      "gridPos": { "h": 7, "w": 12, "x": 12, "y": 14 },
      "id": 10,
      "targets": [
        {
          "expr": "rate(pg_stat_user_tables_n_tup_upd{schemaname=~\"route|user|images\",job=\"postgres-exporter\"}[5m])",
