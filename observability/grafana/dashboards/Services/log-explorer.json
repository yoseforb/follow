{
  "annotations": { "list": [] },
  "editable": true,
  "graphTooltip": 1,
  "links": [],
  "panels": [
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 100,
      "title": "Log Volume",
      "type": "row"
    },
    {
      "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
      "fieldConfig": {
        "defaults": {
          "custom": { "drawStyle": "bars", "fillOpacity": 50, "stacking": { "mode": "normal" } },
          "unit": "short"
        }
      },
      "gridPos": { "h": 6, "w": 16, "x": 0, "y": 1 },
      "id": 1,
      "targets": [
        {
          "expr": "sum by (container) (count_over_time({container=~\"$container\"} [1m]))",
          "legendFormat": "{{container}}"
        }
      ],
      "title": "Log Volume by Container",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
      "fieldConfig": {
        "defaults": {
          "custom": { "drawStyle": "bars", "fillOpacity": 50, "stacking": { "mode": "normal" } },
          "unit": "short",
          "color": { "mode": "palette-classic-by-name" }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "error" },
            "properties": [{ "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } }]
          },
          {
            "matcher": { "id": "byName", "options": "warn" },
            "properties": [{ "id": "color", "value": { "fixedColor": "yellow", "mode": "fixed" } }]
          },
          {
            "matcher": { "id": "byName", "options": "fatal" },
            "properties": [{ "id": "color", "value": { "fixedColor": "dark-red", "mode": "fixed" } }]
          },
          {
            "matcher": { "id": "byName", "options": "panic" },
            "properties": [{ "id": "color", "value": { "fixedColor": "dark-red", "mode": "fixed" } }]
          }
        ]
      },
      "gridPos": { "h": 6, "w": 8, "x": 16, "y": 1 },
      "id": 2,
      "targets": [
        {
          "expr": "sum by (detected_level) (count_over_time({container=~\"$container\"} [1m]))",
          "legendFormat": "{{detected_level}}"
        }
      ],
      "title": "Log Level Distribution",
      "type": "timeseries"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 7 },
      "id": 101,
      "title": "Error & Warning Logs",
      "type": "row"
    },
    {
      "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
      "fieldConfig": {
        "defaults": {
          "custom": { "drawStyle": "bars", "fillOpacity": 70 },
          "unit": "short",
          "color": { "fixedColor": "red", "mode": "fixed" }
        }
      },
      "gridPos": { "h": 5, "w": 24, "x": 0, "y": 8 },
      "id": 3,
      "targets": [
        {
          "expr": "sum by (container) (count_over_time({container=~\"$container\"} | json | level=~\"error|fatal|panic\" [1m]))",
          "legendFormat": "{{container}}"
        }
      ],
      "title": "Error / Fatal / Panic Volume",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
      "gridPos": { "h": 12, "w": 24, "x": 0, "y": 13 },
      "id": 4,
      "options": {
        "showTime": true,
        "showLabels": true,
        "showCommonLabels": false,
        "wrapLogMessage": true,
        "prettifyLogMessage": false,
        "enableLogDetails": true,
        "sortOrder": "Descending",
        "dedupStrategy": "none"
      },
      "targets": [
        {
          "expr": "{container=~\"$container\"} | json | level=~\"error|fatal|panic\"",
          "legendFormat": ""
        }
      ],
      "title": "Error Logs",
      "type": "logs"
    },
    {
      "collapsed": true,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 25 },
      "id": 102,
      "title": "All Logs",
      "type": "row",
      "panels": [
        {
          "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
          "gridPos": { "h": 16, "w": 24, "x": 0, "y": 26 },
          "id": 5,
          "options": {
            "showTime": true,
            "showLabels": true,
            "showCommonLabels": false,
            "wrapLogMessage": true,
            "prettifyLogMessage": false,
            "enableLogDetails": true,
            "sortOrder": "Descending",
            "dedupStrategy": "none"
          },
          "targets": [
            {
              "expr": "{container=~\"$container\"} |~ \"$search\"",
              "legendFormat": ""
            }
          ],
          "title": "All Logs",
          "type": "logs"
        }
      ]
    }
  ],
  "refresh": "30s",
  "schemaVersion": 41,
  "tags": ["logs"],
  "templating": {
    "list": [
      {
        "current": { "selected": false, "text": "Loki", "value": "Loki" },
        "hide": 0,
        "includeAll": false,
        "name": "DS_LOKI",
        "options": [],
        "query": "loki",
        "type": "datasource"
      },
      {
        "allValue": ".+",
        "current": { "selected": true, "text": ["All"], "value": ["$__all"] },
        "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
        "definition": "label_values(container)",
        "hide": 0,
        "includeAll": true,
        "multi": true,
        "name": "container",
        "query": "label_values(container)",
        "refresh": 2,
        "sort": 1,
        "type": "query"
      },
      {
        "current": { "selected": false, "text": "", "value": "" },
        "hide": 0,
        "name": "search",
        "options": [{ "selected": true, "text": "", "value": "" }],
        "query": "",
        "type": "textbox"
      }
    ]
  },
  "time": { "from": "now-1h", "to": "now" },
  "title": "Log Explorer",
  "uid": "log-explorer-overview"
}
