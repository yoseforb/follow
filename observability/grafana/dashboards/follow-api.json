{
  "annotations": { "list": [] },
  "editable": true,
  "graphTooltip": 1,
  "links": [],
  "panels": [
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 100,
      "title": "HTTP Layer",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "decimals": 1,
          "color": { "mode": "thresholds" },
          "thresholds": { "steps": [{ "color": "green", "value": null }] }
        }
      },
      "gridPos": { "h": 6, "w": 6, "x": 0, "y": 1 },
      "id": 1,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] } },
      "title": "HTTP RPS",
      "type": "stat",
      "targets": [
        {
          "expr": "sum(rate(follow_api_http_requests_total[5m]))",
          "legendFormat": "rps"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": { "drawStyle": "line", "fillOpacity": 10 }
        }
      },
      "gridPos": { "h": 6, "w": 8, "x": 6, "y": 1 },
      "id": 2,
      "title": "HTTP Latency (p50 / p95 / p99)",
      "type": "timeseries",
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(follow_api_http_request_duration_seconds_bucket[5m])) by (le))",
          "legendFormat": "p50"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(follow_api_http_request_duration_seconds_bucket[5m])) by (le))",
          "legendFormat": "p95"
        },
        {
          "expr": "histogram_quantile(0.99, sum(rate(follow_api_http_request_duration_seconds_bucket[5m])) by (le))",
          "legendFormat": "p99"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.01 },
              { "color": "red", "value": 0.05 }
            ]
          }
        }
      },
      "gridPos": { "h": 6, "w": 6, "x": 14, "y": 1 },
      "id": 3,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] } },
      "title": "HTTP 5xx Error Rate",
      "type": "stat",
      "targets": [
        {
          "expr": "sum(rate(follow_api_http_requests_total{status_code=~\"5..\"}[5m])) / sum(rate(follow_api_http_requests_total[5m]))",
          "legendFormat": "error_rate"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "decimals": 1,
          "color": { "mode": "thresholds" },
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "red", "value": 10 }
            ]
          }
        }
      },
      "gridPos": { "h": 6, "w": 4, "x": 20, "y": 1 },
      "id": 4,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] } },
      "title": "Rate Limited / sec",
      "type": "stat",
      "targets": [
        {
          "expr": "sum(rate(follow_api_http_rate_limited_total[5m]))",
          "legendFormat": "429s/sec"
        }
      ]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 7 },
      "id": 101,
      "title": "Module Layer",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": { "unit": "ops", "custom": { "drawStyle": "bars" } }
      },
      "gridPos": { "h": 6, "w": 8, "x": 0, "y": 8 },
      "id": 5,
      "title": "Command / Query Throughput by Module",
      "type": "timeseries",
      "targets": [
        {
          "expr": "sum(rate(follow_api_module_operations_total[5m])) by (module)",
          "legendFormat": "{{module}}"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": { "unit": "percentunit", "custom": { "drawStyle": "line" } }
      },
      "gridPos": { "h": 6, "w": 8, "x": 8, "y": 8 },
      "id": 6,
      "title": "Module Error Rate",
      "type": "timeseries",
      "targets": [
        {
          "expr": "sum(rate(follow_api_module_operations_total{status=\"error\"}[5m])) by (module) / sum(rate(follow_api_module_operations_total[5m])) by (module)",
          "legendFormat": "{{module}}"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": { "unit": "s", "custom": { "drawStyle": "line" } }
      },
      "gridPos": { "h": 6, "w": 8, "x": 16, "y": 8 },
      "id": 7,
      "title": "Module p95 Duration",
      "type": "timeseries",
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(follow_api_module_operation_duration_seconds_bucket[5m])) by (le, module))",
          "legendFormat": "{{module}}"
        }
      ]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 14 },
      "id": 102,
      "title": "Event Bus",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": { "unit": "ops", "custom": { "drawStyle": "line" } }
      },
      "gridPos": { "h": 6, "w": 8, "x": 0, "y": 15 },
      "id": 8,
      "title": "Events Published / sec",
      "type": "timeseries",
      "targets": [
        {
          "expr": "sum(rate(follow_api_eventbus_events_published_total[5m])) by (topic)",
          "legendFormat": "{{topic}}"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": { "unit": "s", "custom": { "drawStyle": "line" } }
      },
      "gridPos": { "h": 6, "w": 8, "x": 8, "y": 15 },
      "id": 9,
      "title": "Handler Duration p95",
      "type": "timeseries",
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(follow_api_eventbus_handler_duration_seconds_bucket[5m])) by (le, topic))",
          "legendFormat": "{{topic}}"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "decimals": 1,
          "color": { "mode": "thresholds" },
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 1 }
            ]
          }
        }
      },
      "gridPos": { "h": 6, "w": 8, "x": 16, "y": 15 },
      "id": 10,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] } },
      "title": "Poison Queue + Retries / sec",
      "type": "stat",
      "targets": [
        {
          "expr": "sum(rate(follow_api_eventbus_poison_queue_total[5m]))",
          "legendFormat": "poison/sec"
        },
        {
          "expr": "sum(rate(follow_api_eventbus_handler_retries_total[5m]))",
          "legendFormat": "retries/sec"
        }
      ]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 21 },
      "id": 103,
      "title": "Scheduler",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": { "decimals": 0 }
      },
      "gridPos": { "h": 6, "w": 12, "x": 0, "y": 22 },
      "id": 11,
      "title": "Job Runs (last 1h)",
      "description": "Number of job executions per job and status in the last hour",
      "type": "table",
      "targets": [
        {
          "expr": "sum(increase(follow_api_scheduler_job_runs_total[1h])) by (job, status)",
          "legendFormat": "{{job}} ({{status}})",
          "format": "table",
          "instant": true
        }
      ],
      "transformations": [
        { "id": "organize", "options": { "excludeByName": { "Time": true, "__name__": true, "instance": true } } }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": { "unit": "s", "custom": { "drawStyle": "bars" } }
      },
      "gridPos": { "h": 6, "w": 12, "x": 12, "y": 22 },
      "id": 12,
      "title": "Job Duration p95",
      "type": "timeseries",
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(follow_api_scheduler_job_duration_seconds_bucket[5m])) by (le, job))",
          "legendFormat": "{{job}}"
        }
      ]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 28 },
      "id": 104,
      "title": "Infrastructure",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": { "unit": "short", "decimals": 0, "custom": { "drawStyle": "line", "fillOpacity": 20 } }
      },
      "gridPos": { "h": 6, "w": 6, "x": 0, "y": 29 },
      "id": 13,
      "title": "DB Pool Connections",
      "type": "timeseries",
      "targets": [
        { "expr": "follow_api_db_pool_acquired_connections", "legendFormat": "acquired" },
        { "expr": "follow_api_db_pool_idle_connections", "legendFormat": "idle" },
        { "expr": "follow_api_db_pool_max_connections", "legendFormat": "max" }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "decimals": 0,
          "color": { "mode": "thresholds" },
          "thresholds": { "steps": [{ "color": "green", "value": null }] }
        }
      },
      "gridPos": { "h": 6, "w": 4, "x": 6, "y": 29 },
      "id": 14,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] } },
      "title": "SSE Active Connections",
      "type": "stat",
      "targets": [
        { "expr": "follow_api_sse_active_connections", "legendFormat": "active" }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": { "unit": "ops", "custom": { "drawStyle": "line" } }
      },
      "gridPos": { "h": 6, "w": 4, "x": 10, "y": 29 },
      "id": 24,
      "title": "SSE Events / sec",
      "type": "timeseries",
      "targets": [
        { "expr": "sum(rate(follow_api_sse_events_sent_total[5m])) by (type)", "legendFormat": "{{type}}" }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": { "unit": "ops", "custom": { "drawStyle": "line" } }
      },
      "gridPos": { "h": 6, "w": 5, "x": 14, "y": 29 },
      "id": 15,
      "title": "Valkey Consumer Rate",
      "type": "timeseries",
      "targets": [
        {
          "expr": "sum(rate(follow_api_valkey_consumer_messages_processed_total[5m])) by (result)",
          "legendFormat": "{{result}}"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": { "unit": "s", "custom": { "drawStyle": "line" } }
      },
      "gridPos": { "h": 6, "w": 5, "x": 19, "y": 29 },
      "id": 16,
      "title": "Storage + Valkey p95 Duration",
      "type": "timeseries",
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(follow_api_storage_operation_duration_seconds_bucket[5m])) by (le, operation))",
          "legendFormat": "storage: {{operation}}"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(follow_api_valkey_consumer_message_duration_seconds_bucket[5m])) by (le))",
          "legendFormat": "valkey consumer"
        }
      ]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 35 },
      "id": 105,
      "title": "Security & Auth",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": { "unit": "ops", "custom": { "drawStyle": "line" } }
      },
      "gridPos": { "h": 6, "w": 8, "x": 0, "y": 36 },
      "id": 17,
      "title": "Auth Token Failures / sec",
      "type": "timeseries",
      "targets": [
        {
          "expr": "sum(rate(follow_api_auth_token_failures_total[5m])) by (reason)",
          "legendFormat": "{{reason}}"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": { "unit": "s", "custom": { "drawStyle": "line" } }
      },
      "gridPos": { "h": 6, "w": 8, "x": 8, "y": 36 },
      "id": 18,
      "title": "OAuth Validation p95 Duration",
      "type": "timeseries",
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(follow_api_oauth_validation_duration_seconds_bucket[5m])) by (le, provider))",
          "legendFormat": "{{provider}}"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": { "unit": "ops", "custom": { "drawStyle": "line" } }
      },
      "gridPos": { "h": 6, "w": 8, "x": 16, "y": 36 },
      "id": 19,
      "title": "Email Sent / sec",
      "type": "timeseries",
      "targets": [
        {
          "expr": "sum(rate(follow_api_email_sent_total[5m])) by (purpose, status)",
          "legendFormat": "{{purpose}} ({{status}})"
        }
      ]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 42 },
      "id": 106,
      "title": "Background Jobs & Service Health",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": { "unit": "ops", "custom": { "drawStyle": "bars" } }
      },
      "gridPos": { "h": 6, "w": 12, "x": 0, "y": 43 },
      "id": 20,
      "title": "Cleanup Items / sec",
      "type": "timeseries",
      "targets": [
        {
          "expr": "sum(rate(follow_api_cleanup_items_total[5m])) by (scanner, action)",
          "legendFormat": "{{scanner}}: {{action}}"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "unit": "dateTimeAsIso",
          "color": { "mode": "thresholds" },
          "thresholds": { "steps": [{ "color": "blue", "value": null }] }
        }
      },
      "gridPos": { "h": 6, "w": 4, "x": 12, "y": 43 },
      "id": 22,
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "textMode": "value"
      },
      "title": "Server Started At",
      "description": "Timestamp when the server process started",
      "type": "stat",
      "targets": [
        {
          "expr": "follow_api_server_start_time_seconds * 1000",
          "legendFormat": "started"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "unit": "dtdurations",
          "color": { "mode": "thresholds" },
          "thresholds": { "steps": [{ "color": "green", "value": null }] }
        }
      },
      "gridPos": { "h": 6, "w": 8, "x": 16, "y": 43 },
      "id": 21,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] } },
      "title": "Uptime",
      "type": "stat",
      "targets": [
        {
          "expr": "time() - follow_api_server_start_time_seconds",
          "legendFormat": "uptime"
        }
      ]
    }
