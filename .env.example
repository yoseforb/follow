# Follow Platform — Docker Compose Environment
# Copy to .env and adjust as needed:  cp .env.example .env

# ── Host Port Overrides ─────────────────────────────────────────
# Set these to avoid conflicts with native services running on default ports
POSTGRES_HOST_PORT=15432
VALKEY_HOST_PORT=16379
MINIO_HOST_PORT=19000
MINIO_CONSOLE_HOST_PORT=19001
API_HOST_PORT=18080
GATEWAY_HOST_PORT=18090

# ── Host IP (for Flutter app → gateway upload URLs) ──────────────
# Your LAN IP so the phone can reach the gateway.
# Detect: hostname -I | awk '{print $1}'
HOST_IP=192.168.68.55

# ── Sensitive Values ─────────────────────────────────────────────
POSTGRES_DB=follow
POSTGRES_USER=follow
POSTGRES_PASSWORD=follow
POSTGRES_SSLMODE=disable
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_ACCESS_KEY_ID=minioadmin
MINIO_SECRET_ACCESS_KEY=minioadmin
# Host embedded in presigned MinIO URLs. On the laptop this must
# include the port (Docker publishes MinIO on :9000). On the
# Hetzner box, set this to the public download hostname with NO
# port and set MINIO_USE_SSL=true — the MinIO SDK will infer 443.
#   Laptop:   MINIO_EXTERNAL_ENDPOINT=localhost:9000
#   Hetzner:  MINIO_EXTERNAL_ENDPOINT=download.follow-ap.com
MINIO_EXTERNAL_ENDPOINT=localhost:9000
MINIO_USE_SSL=false
# Generate fresh dev keys: python3 -c "from cryptography.hazmat.primitives.asymmetric.ed25519 import Ed25519PrivateKey; ..."
JWT_SECRET=docker-dev-jwt-secret-min-32-characters-long
FOLLOW_API_ED25519_PRIVATE_KEY=<base64-encoded-ed25519-private-key-seed>
FOLLOW_API_ED25519_PUBLIC_KEY=<base64-encoded-ed25519-public-key>
